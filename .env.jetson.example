# Copy to .env on the Jetson and edit only the values that differ.

# Robot STA-mode IP. This is the dog, not the Jetson.
GO2_IP=192.168.123.121
GO2_WEBRTC_METHOD=LocalSTA
# GO2_SERIAL_NUMBER=
# GO2_REMOTE_USERNAME=
# GO2_REMOTE_PASSWORD=
# GO2_REMOTE_REGION=global
# GO2_REMOTE_DEVICE_TYPE=Go2
GO2_AES_128_KEY=

# Local reasoning model. Keep this small on an Orin Nano.
OLLAMA_MODEL=qwen3:1.7b

# Leave blank when Ollama and Python both run on the Jetson.
# OLLAMA_HOST=

# Browser cockpit served by the Jetson.
GO2_GUI_HOST=0.0.0.0
GO2_GUI_PORT=8775
GO2_MAPS_DIR=maps
# GO2_START_MAP=maps/room.json

# Vision and follow settings.
GO2_DETECTOR=yolo
GO2_YOLO_MODEL=yolov8n.pt
GO2_YOLO_THRESHOLD=0.55
GO2_YOLO_DEVICE=0
GO2_FACE_DETECTION=1
GO2_FOLLOW_SOURCE=visual-or-sound

# LiDAR calibration knobs. Use these if the map appears rotated, mirrored, or
# axis-swapped. The GUI also exposes a live transform endpoint.
GO2_LIDAR_ROTATE_DEG=0
GO2_LIDAR_FLIP_X=0
GO2_LIDAR_FLIP_Y=0
GO2_LIDAR_SWAP_XY=0

# Set to 1 only for bench testing when YOLO is not installed yet.
GO2_ALLOW_NO_DETECTOR=0

# Exploration defaults used by the AI CLI/tool layer.
ENABLE_EXPLORATION=1
EXPLORATION_MODE=relaxed
EXPLORATION_MIN_OBSTACLE_M=0.35
EXPLORATION_MAX_DURATION_S=15

# Optional diagnostics.
# VERBOSE_WEBRTC_LOGS=1
