# Go2 STA-mode IP (the dog). Confirmed live: 192.168.123.121.
# 192.168.123.18 is the Jetson, not the robot - don't point this at it.
GO2_IP=192.168.123.121

# Per-device AES-128 key. Required only on Go2 firmware >= 1.1.15 when
# the cloud handshake returns data2=3. Leave blank if your firmware
# doesn't ask for it; the driver passes it through only when set.
GO2_AES_128_KEY=

# Default is qwen3:1.7b so this app fits on a Jetson Orin Nano.
OLLAMA_MODEL=qwen3:1.7b

# Only set OLLAMA_HOST when the Python brain and the Ollama server are
# in different environments.
# OLLAMA_HOST=

# Optional. Set to "normal" if sport commands appear to be silently ignored.
# FORCE_MOTION_MODE=

# Autonomous room exploration. Modes:
# telemetry = require fresh nonzero range_obstacle
# relaxed   = use range_obstacle if available, otherwise roam in short arcs
# blind     = ignore range_obstacle entirely; use only in a clear area
# ENABLE_EXPLORATION=1
# EXPLORATION_MODE=telemetry
# EXPLORATION_MIN_OBSTACLE_M=0.35
# EXPLORATION_MAX_DURATION_S=15

# Optional diagnostics. Set to 1 to restore upstream INFO logs for every
# incoming WebRTC/sport-state packet.
# VERBOSE_WEBRTC_LOGS=1
