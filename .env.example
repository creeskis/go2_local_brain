# Go2 STA-mode IP (the dog). Confirmed live: 192.168.123.121.
# 192.168.123.18 is the Jetson, not the robot - don't point this at it.
GO2_IP=192.168.123.121

# WebRTC method. For STA-mode Go2 on a local network, keep LocalSTA.
# Supported by unitree_webrtc_connect: LocalSTA, LocalAP, Remote.
GO2_WEBRTC_METHOD=LocalSTA
# Optional LocalSTA discovery by serial number, or required for Remote mode.
# GO2_SERIAL_NUMBER=
# Remote mode only:
# GO2_REMOTE_USERNAME=
# GO2_REMOTE_PASSWORD=
# GO2_REMOTE_REGION=global
# GO2_REMOTE_DEVICE_TYPE=Go2

# Per-device AES-128 key. Required only on Go2 firmware >= 1.1.15 when
# the cloud handshake returns data2=3. Leave blank if your firmware
# doesn't ask for it; the driver passes it through only when set.
GO2_AES_128_KEY=

# Ollama model used by LocalRobotBrain for tool calling.
#
# Recommended ladder (8GB Jetson Orin Nano shared RAM):
#   gemma3:4b   (~3 GB) - DEFAULT. Vision-capable; good tool calling for size.
#   qwen3:4b    (~2.5 GB) - faster, slightly weaker tool calls.
#   qwen3:8b    (~5 GB) - matches DimensionOS default. Tightest fit on Orin
#                          Nano; may swap when vision + autonomy also active.
#   lfm2.5:8b   (~5 GB) - tuned specifically for tool calling.
#
# Tip: edit ~/.go2/env.local instead of this file to override per-host.
OLLAMA_MODEL=gemma3:4b

# Only set OLLAMA_HOST when the Python brain and the Ollama server are
# in different environments.
# OLLAMA_HOST=

# Optional. Set to "normal" if sport commands appear to be silently ignored.
# FORCE_MOTION_MODE=

# Autonomous room exploration. Modes:
# telemetry = require fresh nonzero range_obstacle
# relaxed   = use range_obstacle if available, otherwise roam in short arcs
# blind     = ignore range_obstacle entirely; use only in a clear area
# ENABLE_EXPLORATION=1
# EXPLORATION_MODE=telemetry
# EXPLORATION_MIN_OBSTACLE_M=0.35
# EXPLORATION_MAX_DURATION_S=15

# Optional diagnostics. Set to 1 to restore upstream INFO logs for every
# incoming WebRTC/sport-state packet.
# VERBOSE_WEBRTC_LOGS=1

# Local cockpit USB trigger relay. Passwords are intentionally blank here;
# set them only in your private .env or use SSH keys.
GUN_DOG_HOST=192.168.123.121
GUN_DOG_USER=root
GUN_DOG_PASSWORD=
GUN_JETSON_HOST=10.42.0.2
GUN_JETSON_USER=unitree
GUN_JETSON_PASSWORD=
GUN_FIRE_COMMAND=cat /dev/ttyUSB0 | xxd
GUN_STOP_COMMAND=printf '\x30' > /dev/ttyUSB0
