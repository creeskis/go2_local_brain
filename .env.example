# Go2 STA-mode IP (the dog). Confirmed live: 192.168.123.121.
# 192.168.123.18 is the Jetson, not the robot - don't point this at it.
GO2_IP=192.168.123.121

# Per-device AES-128 key. Required only on Go2 firmware >= 1.1.15 when
# the cloud handshake returns data2=3. Leave blank if your firmware
# doesn't ask for it; the driver passes it through only when set.
GO2_AES_128_KEY=

# Default is qwen3:1.7b so this app fits on a Jetson Orin Nano. For
# offboard / laptop planners with more RAM, qwen3:8b and lfm2.5:8b have
# noticeably better tool-call reliability; see README "Model choice".
OLLAMA_MODEL=qwen3:1.7b

# Only set OLLAMA_HOST when the Python brain and the Ollama server are
# in different environments. Leave unset for Jetson-local production
# and for "WSL app + WSL Ollama". Set to http://<host-ip>:11434 when
# the brain runs inside WSL but Ollama runs on the Windows host.
# OLLAMA_HOST=

# Optional. Set to "normal" if sport commands appear to be silently
# ignored on connect - the driver will then query MOTION_SWITCHER and
# switch the controller to the named mode (upstream's sportmode.py
# example does this). Leave blank to skip; Cooper's custom 1.1.7
# package may already pick the right mode.
# FORCE_MOTION_MODE=
