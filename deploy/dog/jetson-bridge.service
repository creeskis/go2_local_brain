[Unit]
Description=Add 10.42.0.0/24 bridge subnet for Jetson NAT
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
RemainAfterExit=yes
# Add the bridge IP alongside the dog's existing eth0 addresses.
# 2>/dev/null + || true so re-applies don't fail when the address is
# already present.
ExecStart=/bin/sh -c '/usr/sbin/ip addr add 10.42.0.1/24 dev eth0 2>/dev/null || true'
ExecStart=/usr/sbin/sysctl -w net.ipv4.ip_forward=1
ExecStart=/usr/sbin/iptables -t nat -A POSTROUTING -s 10.42.0.0/24 -o wlan0 -j MASQUERADE
ExecStart=/usr/sbin/iptables -A FORWARD -i eth0 -s 10.42.0.0/24 -o wlan0 -j ACCEPT
ExecStart=/usr/sbin/iptables -A FORWARD -i wlan0 -o eth0 -d 10.42.0.0/24 -m state --state RELATED,ESTABLISHED -j ACCEPT
# Symmetric teardown so systemctl disable --now undoes everything cleanly.
ExecStop=/bin/sh -c '/usr/sbin/ip addr del 10.42.0.1/24 dev eth0 2>/dev/null || true'
ExecStop=/usr/sbin/sysctl -w net.ipv4.ip_forward=0
ExecStop=/bin/sh -c '/usr/sbin/iptables -t nat -D POSTROUTING -s 10.42.0.0/24 -o wlan0 -j MASQUERADE 2>/dev/null || true'
ExecStop=/bin/sh -c '/usr/sbin/iptables -D FORWARD -i eth0 -s 10.42.0.0/24 -o wlan0 -j ACCEPT 2>/dev/null || true'
ExecStop=/bin/sh -c '/usr/sbin/iptables -D FORWARD -i wlan0 -o eth0 -d 10.42.0.0/24 -m state --state RELATED,ESTABLISHED -j ACCEPT 2>/dev/null || true'

[Install]
WantedBy=multi-user.target
